    },
    {
        "index": 11,
        "start": "00:00:21,760",
        "end": "00:00:23,080",
        "original": "Você não vê isso, não?",
        "glossa": "VOCÊ NÃO VÊ ISSO NÃO"
    },
    {
        "index": 12,
        "start": "00:00:23,080",
        "end": "00:00:25,359",
        "original": "Que os aplicativos não quebram na casa, os restaurantes.",
        "glossa": "QUE OS APLICATIVOS NÃO QUEBRAM NA CASA OS RESTAURANTES"
    },
    {
        "index": 13,
